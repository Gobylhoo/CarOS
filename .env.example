# Copy this file to .env and fill in your Supabase project values.
# Find them in Supabase: Project Settings → API.
# These are safe to expose in the frontend — Row Level Security
# (see supabase_setup.sql) is what protects your data.

VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (set in Vercel dashboard, NOT prefixed with VITE_):
# ANTHROPIC_API_KEY=sk-ant-...
